# These env vars can be set to configure the `npm run start` task
# these options are also available on the command line.

# large sites can use a lot of heap. There is probably a leak we haven't found yet.
# e.g. a site with 1112 pages required 16GB heap on macos
HEAP_SIZE=16384

# Optional comma-separated list of Alfa rule IDs to ignore in reports (default undefined)
# for example, when the designer overrules the overboard color contrast requirement
# IGNORE_RULES=sia-r69

# Uncomment to include "cantTell" outcomes in reports
# WARNINGS=true

# the checker will include all pages in the sitemap
SITEMAP=https://outdoor.wildlifeillinois.org/sitemap.xml

# the base name for the generated report.
OUTPUT=oij-a11y-report

# only check paths including the filter string
# FILTER="/narp/"

# specify concurrency (default 3)
CONCURRENCY=1

# Path to a JSON file containing a string[] of URLs to scan directly (alternative to SITEMAP)
URLS=./oij-urls.json

# Base URL (with scheme) prepended to relative paths in the URL file; enables localhost dev mode
#BASE_URL=http://localhost:3000
BASE_URL=https://outdoor.wildlifeillinois.org

# JWT token to inject as a cookie on all page requests (for authenticated sites)
# prod
#JWT_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJodHRwczovL2JldGEud2lsZC53aWxkbGlmZWlsbGlub2lzLm9yZyIsInVzZXJJZCI6IjYzYmRlYWJiZjk3MWI2ZmJiZWU1MmY2NSIsInJvbGUiOiIqIiwianRpIjoiMGY2ZDUxY2EtZGQ0OC00NTQyLThlYWMtMjM3ZmM4MWE4NWVkIiwiaWF0IjoxNzc1MDcwOTkyLCJleHAiOjE3NzUxNTczOTJ9.FimRkhSM5duxtjQwco43AkCvPJj5AIQCk4vjKH9tVDM
# localhost
# JWT_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJodHRwOi8vbG9jYWxob3N0OjMwMDAiLCJ1c2VySWQiOiI2M2JkZWFiYmY5NzFiNmZiYmVlNTJmNjUiLCJyb2xlIjoiKiIsImp0aSI6IjE5ZjI3Njc2LWU0ZjMtNGFlMy1iNTk2LWQ4NGYwOTY5ZTE1ZCIsImlhdCI6MTc3NTEwMDY5MiwiZXhwIjoxNzc1NzA1NDkyfQ.tcRTLGWQXNA8VFAVhWUZ_uHAOqtDWSOGWDNuV8hw5lc
#JWT_COOKIE_NAME="wild:token"

# Capture browser console output (log, warn, error) per page — included in HTML/XLSX/JSON reports
CAPTURE_CONSOLE=true

# Number of times to retry a page if it errors OR has violations (default: 1)
# RETRY=3
