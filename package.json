{
  "name": "siteimprove-sitemap-checker",
  "version": "1.0.0",
  "description": "CLI tool to audit web accessibility using Siteimprove Alfa against all pages in an XML sitemap",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.private/.env.2wav --max-old-space-size=8192 --import tsx src/cli.ts -f html -v --wait 4000 --timeout 30000",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "mocha",
    "test:live": "LIVE_TESTS=1 mocha --grep ncran"
  },
  "dependencies": {
    "@siteimprove/alfa-playwright": "^0.81.0",
    "@siteimprove/alfa-test-utils": "^0.81.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.0",
    "p-limit": "^6.1.0",
    "playwright": "^1.50.0",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.35",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
