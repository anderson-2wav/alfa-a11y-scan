# Example configuration for alfa-a11y-scan.
#
# Copy this file to `.env` and edit for your site:
#   cp .env.example .env
#
# Load it when running the CLI:
#   node --env-file=.env --import tsx src/cli.ts [sitemap-url] [options]
#
# Everything here is optional and has a command-line flag equivalent; a flag
# always overrides the matching env var. Options that are FLAG-ONLY (no env
# var) are noted below — putting them here has no effect.

# ── Engine ──────────────────────────────────────────────────────────────
# Accessibility engine to run: alfa | opena11y | both   (default: alfa)
#   alfa     — Siteimprove Alfa (rule IDs like sia-r69)
#   opena11y — OpenA11y Evaluation Library (rule IDs like COLOR_1)
#   both     — run both engines and emit one combined report
ENGINE=alfa

# ── What to scan (choose SITEMAP *or* URLS) ─────────────────────────────
# A sitemap URL to crawl — every <url> in it is scanned. (Also accepted as
# the positional CLI argument.) Both <urlset> and <sitemapindex> are supported.
SITEMAP=https://example.com/sitemap.xml

# ...or scan a fixed list of URLs instead of a sitemap: path to a JSON file
# containing an array of URL strings. Relative paths are resolved against BASE_URL.
# URLS=./urls.json
# BASE_URL=https://example.com

# Only scan sitemap URLs matching this regex (optional).
# FILTER=/blog/

# ── Report output ───────────────────────────────────────────────────────
# Output file base name; the extension is added from the format (--format, default csv).
OUTPUT=example-report

# Site name — prefixes the report title as "<NAME> Accessibility Scan Report"
# (shown in the HTML <title>/<h1> and at the top of the XLSX Summary sheet).
NAME=Example.com

# ── Rules & warnings ────────────────────────────────────────────────────
# Comma-separated rule IDs to suppress. Alfa uses sia-rN; OpenA11y uses
# UPPER_SNAKE_CASE (e.g. COLOR_1). Applies to whichever engine(s) run.
# IGNORE_RULES=sia-r69,COLOR_1

# Comma-separated rule IDs to run EXCLUSIVELY (all others skipped).
# ONLY_RULES=sia-r69

# Include "needs review" results (Alfa cantTell / OpenA11y manual checks), per engine.
# Alfa warnings are manageable and default ON; OpenA11y manual checks are
# voluminous and default OFF.
# WARNINGS_ALFA=true
# WARNINGS_OPENA11Y=false

# ── Authenticated sites ─────────────────────────────────────────────────
# JWT token injected as a cookie on every page request. The value below is a
# FAKE, non-functional example — replace it with your own token.
JWT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJodHRwczovL2V4YW1wbGUuY29tIiwic3ViIjoiZXhhbXBsZS11c2VyIiwicm9sZSI6InZpZXdlciIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoxOTAwMDAwMDAwfQ.FAKE_SIGNATURE_example_only_do_not_use
# Cookie name to store the JWT in (default: token).
JWT_COOKIE_NAME=token

# ── Crawl behavior ──────────────────────────────────────────────────────
# Pages audited in parallel (default: 3).
CONCURRENCY=3

# Include WAI-ARIA authoring-practice rules (Alfa). Set to "false" to exclude.
# Default: true (matches the Siteimprove scanner).
# INCLUDE_ARIA=true

# Retry a page this many times if it errors or has violations (default: 0).
# RETRY=2

# Stop scanning after the first page error or violation and write a partial report.
# STOP_ON_FAIL=true

# Capture browser console output (log/warn/error) per page; included in reports.
# CAPTURE_CONSOLE=true
# Also write the captured console output to a file (relative paths resolve to cwd).
# Setting this implies CAPTURE_CONSOLE.
# CONSOLE_LOG_FILE=./console.log

# ── Flag-only options (NOT env vars — shown here for reference only) ─────
# These must be passed on the command line; setting them here does nothing:
#   --format (-f) csv|xlsx|json|html      (default csv)
#   --wcag-level  a|aa|aaa                (default aa)
#   --timeout     <ms>                    (default 30000)
#   --wait        <ms>                    (default 2000)
#   --pause       <ms> between page loads (default 0)
#   --verbose (-v)
